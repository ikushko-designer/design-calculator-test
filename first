<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Калькулятор проекта</title>

<style>

body{
  font-family:Arial,sans-serif;
  background:#f2f2f2;
  padding:20px;
  margin:0;
}
/* ОСНОВНОЙ КОНТЕЙНЕР */
body{
  display:flex;
  flex-direction:column;
  align-items:center;
}

/* Ширина всей страницы */
.card{
  width:100%;
  max-width:933px; /* ширина под 5 фото */
  box-sizing:border-box;
}

/* Чтобы карточки дизайнеров тоже были по ширине контейнера */
.designer{
  width:100%;
  box-sizing:border-box;
}

/* 5 фотографий ровно в ряд */
.carousel{
  display:flex;
  gap:8px;
  overflow-x:auto;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  padding-bottom:4px;
}

/* Размер фото */
.carousel-item{
  flex:0 0 auto;
  width:180px;
  height:120px;
  border-radius:8px;
  overflow:hidden;
  scroll-snap-align:start;
  background:#aaa;
}

/* Мобильная адаптация */
@media (max-width:1100px){

  .card{
    max-width:100%;
  }

}

/* Телефон */
@media (max-width:768px){

  body{
    padding:10px;
  }

  .carousel-item{
    width:130px;
    height:90px;
  }

}
.card{
  background:#e9e9e9;
  border-radius:20px;
  padding:20px;
  margin-bottom:20px;
}

h2,h3,h4{
  margin-bottom:10px;
}

.input,
select{
  padding:8px 12px;
  border-radius:12px;
  border:none;
  background:#d6d6d6;
}

.row{
  display:flex;
  gap:10px;
  margin-bottom:10px;
  flex-wrap:wrap;
  align-items:center;
}

.service{
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:8px;
  flex-wrap:wrap;
}

.unit{
  font-size:12px;
  color:#666;
}

.btn{
  background:#ff4d4d;
  border:none;
  padding:8px 20px;
  border-radius:12px;
  color:white;
  cursor:pointer;
  margin-top:10px;
  margin-right:10px;
}

.designer{
  background:white;
  border-radius:20px;
  padding:20px;
  display:flex;
  flex-direction:column;
  gap:12px;
  margin-bottom:20px;
}

.header{
  display:flex;
  gap:18px;
  flex-wrap:wrap;
}

.designer-photo{
  width:120px;
  aspect-ratio:3/4;
  border-radius:14px;
  overflow:hidden;
  flex-shrink:0;
}

.designer-photo img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.header-info{
  display:flex;
  flex-direction:column;
  gap:8px;
  flex:1;
}

.title-line{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.title-line h3{
  margin:0;
}

.city{
  background:#6d35ff;
  color:white;
  padding:5px 12px;
  border-radius:12px;
  font-size:12px;
  font-weight:bold;
}

.tags-row{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}

.tag{
  padding:6px 12px;
  border-radius:12px;
  font-size:12px;
  color:white;
  white-space:nowrap;
}

.tag-green{
  background:#00b578;
}

.tag-blue{
  background:#132e7c;
}

.tag-orange{
  background:#ff7b22;
}

.calc-row{
  display:flex;
  flex-direction:column;
  gap:4px;
}

.service-line{
  display:flex;
  justify-content:flex-start;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.rate{
  font-size:13px;
  font-weight:bold;
}

.amount-box{
  background:#d6d6d6;
  padding:8px 12px;
  border-radius:10px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-size:13px;
}

.amount-box-disabled{
  background:#FFAFC1;
  color:#7a2f4b;
}

/* Кликабельный фрейм */
.amount-box-clickable{
  cursor:pointer;
  transition: background 0.15s;
  user-select: none;
}

.amount-box-clickable:hover{
  background:#c8c8c8;
}

.amount-box-clickable.active{
  background:#b8b8b8;
  border-radius:10px 10px 0 0;
}

/* Иконка-стрелка */
.amount-box-clickable .toggle-icon{
  font-size:11px;
  color:#555;
  margin-left:6px;
  transition: transform 0.2s;
  display:inline-block;
}

.amount-box-clickable.active .toggle-icon{
  transform: rotate(180deg);
}

/* Фрейм без фото — не кликабельный, стрелка скрыта */
.amount-box-no-photos{
  cursor:default;
}

.amount-box-no-photos:hover{
  background:#d6d6d6;
}

/* Карусель */
.carousel-wrap{
  display:none;
  background:#c4c4c4;
  border-radius:0 0 10px 10px;
  padding:10px;
  overflow:hidden;
}

.carousel-wrap.open{
  display:block;
}

.carousel{
  display:flex;
  gap:8px;
  overflow-x:auto;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  padding-bottom:4px;
}

.carousel::-webkit-scrollbar{
  height:4px;
}

.carousel::-webkit-scrollbar-track{
  background:#b0b0b0;
  border-radius:2px;
}

.carousel::-webkit-scrollbar-thumb{
  background:#888;
  border-radius:2px;
}

.carousel-item{
  flex:0 0 auto;
  width:160px;
  height:110px;
  border-radius:8px;
  overflow:hidden;
  scroll-snap-align:start;
  background:#aaa;
}

.carousel-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  cursor:zoom-in;
}

/* Лайтбокс */
#lightbox{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.88);
  z-index:9999;
  align-items:center;
  justify-content:center;
  cursor:zoom-out;
}

#lightbox.open{
  display:flex;
}

#lightbox img{
  width:auto;
  height:auto;

  max-width:80vw;
  max-height:90vh;

  object-fit:contain;

  border-radius:12px;

  box-shadow:0 10px 50px rgba(0,0,0,0.7);

  cursor:default;

  display:block;
}

#lightbox-close{
  position:fixed;
  top:16px;
  right:20px;
  color:white;
  font-size:32px;
  font-weight:bold;
  cursor:pointer;
  line-height:1;
  user-select:none;
  text-shadow:0 2px 6px rgba(0,0,0,0.5);
  z-index:10001;
}

/* Стрелки лайтбокса */
.lightbox-arrow{
  position:fixed;
  top:50%;
  transform:translateY(-50%);
  color:white;
  font-size:48px;
  font-weight:bold;
  cursor:pointer;
  user-select:none;
  text-shadow:0 2px 8px rgba(0,0,0,0.7);
  z-index:10001;
  padding:10px 18px;
  border-radius:50%;
  background:rgba(0,0,0,0.35);
  transition:background 0.15s;
  line-height:1;
}

.lightbox-arrow:hover{
  background:rgba(0,0,0,0.6);
}

#lightbox-prev{
  left:16px;
}

#lightbox-next{
  right:16px;
}

.total{
  margin-top:10px;
  font-weight:bold;
  font-size:22px;
}

.supervision-badge{
  margin-top:10px;
  display:inline-block;
  background:#00aaff;
  color:white;
  padding:8px 14px;
  border-radius:10px;
  font-size:14px;
  font-weight:normal;
}

.contact-btn{
  margin-top:10px;
  background:#00aaff;
  padding:12px 18px;
  border-radius:12px;
  color:white;
  border:none;
  cursor:pointer;
  font-size:14px;
}

.small-input{
  width:60px;
}

@media (max-width:768px){

  .header{
    flex-direction:column;
  }

  .designer-photo{
    width:100%;
    max-width:220px;
  }

  .carousel-item{
    width:130px;
    height:90px;
  }

  .lightbox-arrow{
    font-size:32px;
    padding:6px 12px;
  }

  #lightbox-prev{
    left:6px;
  }

  #lightbox-next{
    right:6px;
  }

}


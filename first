/* =============================================
   ЛАЙТБОКС: состояние текущей карусели
   ============================================= */
let lightboxPhotos = [];  // массив src всех фото текущей карусели
let lightboxIndex  = 0;   // индекс открытого фото

/* Открыть лайтбокс, передав элемент <img> и список src карусели */
function openLightbox(imgEl, photos){
  lightboxPhotos = photos;
  lightboxIndex  = photos.indexOf(imgEl.src);
  if(lightboxIndex < 0) lightboxIndex = 0;
  document.getElementById("lightbox-img").src = photos[lightboxIndex];
  document.getElementById("lightbox").classList.add("open");
  document.body.style.overflow = "hidden";
}

/* Листать вперёд/назад */
function lightboxNav(dir){
  if(lightboxPhotos.length === 0) return;
  lightboxIndex = (lightboxIndex + dir + lightboxPhotos.length) % lightboxPhotos.length;
  document.getElementById("lightbox-img").src = lightboxPhotos[lightboxIndex];
}

function closeLightbox(){
  document.getElementById("lightbox").classList.remove("open");
  document.getElementById("lightbox-img").src = "";
  document.body.style.overflow = "";
  lightboxPhotos = [];
  lightboxIndex  = 0;
}

document.addEventListener("keydown", function(e){
  if(e.key === "Escape")      closeLightbox();
  if(e.key === "ArrowRight")  lightboxNav(1);
  if(e.key === "ArrowLeft")   lightboxNav(-1);
});

/* =============================================
   Генерация HTML карусели
   ============================================= */
function buildCarousel(designerId, serviceKey){

  const photos = portfolioPhotos[designerId]?.[serviceKey];
  if(!photos || photos.length === 0) return { html: "", hasPhotos: false };

  const isVisual = serviceKey === "visual";

  // Передаём весь список фото в обработчик клика через JSON
  const photosJson = JSON.stringify(photos).replace(/"/g, "&quot;");

  const items = photos.map(url =>
    `<div class="carousel-item"><img src="${url}" loading="lazy" onclick="openLightbox(this, JSON.parse(this.closest('.carousel-wrap').dataset.photos))"></div>`
  ).join("");

  const openClass = isVisual ? " open" : "";

  return {
    html: `<div class="carousel-wrap${openClass}" data-photos="${photosJson}"><div class="carousel">${items}</div></div>`,
    hasPhotos: true
  };

}

/* Переключение карусели */
function toggleCarousel(boxEl){

  const wrap = boxEl.nextElementSibling;
  if(!wrap || !wrap.classList.contains("carousel-wrap")) return;

  const isOpen = wrap.classList.contains("open");
  wrap.classList.toggle("open", !isOpen);
  boxEl.classList.toggle("active", !isOpen);

}


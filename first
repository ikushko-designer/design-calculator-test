</div>

<div class="service">
<input type="checkbox" id="visual" checked>
<label>3D-визуализация</label>
<input class="input" type="number" value="62" id="area3">
<span class="unit">кв.м</span>
</div>

<div class="service">
<input type="checkbox" id="table">
<label>Таблица комплектации</label>
<input class="input" type="number" value="50" id="areaTable">
<span class="unit">кв.м</span>
</div>

<div class="service">

<input type="checkbox" id="collage">

<label>2D-коллажи</label>

<input
class="input small-input"
type="number"
value="3"
id="collageCount"
>

<span class="unit">ракурсов</span>

<input
class="input small-input"
type="number"
value="62"
id="collageArea"
>

<span class="unit">кв.м</span>

</div>

<div class="service">
<input type="checkbox" id="supervision">
<label>Авторский надзор</label>
</div>

</div>

<div class="card">

<div class="row">

<label>Бюджет от:</label>
<input class="input" id="budgetMin" value="10000">

<label>до:</label>
<input class="input" id="budgetMax" value="900000">

</div>

<div class="row">

<label>Сортировать:</label>

<select id="sort">
<option value="desc">Сначала дороже</option>
<option value="asc" selected>Сначала дешевле</option>
</select>

</div>

<button class="btn" onclick="calculate()">
Подобрать дизайнера
</button>

<div style="height:20px;"></div>

<div id="results"></div>

</div>

<!-- Лайтбокс -->
<div id="lightbox" onclick="closeLightbox()">
  <span id="lightbox-close" onclick="closeLightbox()">✕</span>
  <span class="lightbox-arrow" id="lightbox-prev" onclick="event.stopPropagation(); lightboxNav(-1)">&#8592;</span>
